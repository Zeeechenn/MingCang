# 复制此文件为 .env 并填入真实值
ANTHROPIC_API_KEY=your_claude_api_key_here

# 数据库
# 留空则自动使用项目根目录下的 stock-sage.db（推荐）
# 如需自定义路径，取消注释并修改：
# DATABASE_URL=sqlite:////your/absolute/path/to/stock-sage.db

# 调度时间（24小时制，北京时间）
SCHEDULE_PREMARKET=08:30
SCHEDULE_POSTMARKET=16:00

# A股数据源（可选，Tushare Pro token，不填则用免费AkShare）
TUSHARE_TOKEN=

# 日志级别
LOG_LEVEL=INFO
