# Copy this file to .env and fill in real values.
#
# Sections mirror backend/config.py Settings.
# Uncomment optional values only when you need to override the code default.
# Keep real keys in .env or a secret manager; never commit them.

# --- 1. LLM providers ---------------------------------------------------------

AI_PROVIDER=local_cli
# ANTHROPIC_API_KEY=<your_anthropic_api_key>  # default: empty
# ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001  # default: claude-haiku-4-5-20251001
# ANTHROPIC_MODEL_CAPABLE=claude-sonnet-4-6  # default: claude-sonnet-4-6
# OPENAI_API_KEY=<your_openai_api_key>  # default: empty
# OPENAI_BASE_URL=  # default: empty
# OPENAI_MODEL_FAST=gpt-4o-mini  # default: gpt-4o-mini
# OPENAI_MODEL_CAPABLE=gpt-4o  # default: gpt-4o
# LOCAL_CLI_MODEL_FAST=claude-haiku-4-5-20251001  # default: claude-haiku-4-5-20251001
# LOCAL_CLI_MODEL_CAPABLE=claude-sonnet-4-6  # default: claude-sonnet-4-6
LOCAL_CLI_TIMEOUT_SECONDS=90
LOCAL_CLI_PREFER_CODEX=true

# --- 2. Database, logging, CORS, and schedules --------------------------------

# DATABASE_URL=sqlite:///./mingcang.db  # default: project-root mingcang.db
LOG_LEVEL=INFO
# CORS_ORIGINS=http://localhost:5173  # default: http://localhost:5173
SCHEDULER_ENABLED=false
SCHEDULE_PREMARKET=08:30
SCHEDULE_POSTMARKET=16:00
SCHEDULE_LONGTERM_DOW=sun
SCHEDULE_LONGTERM_TIME=11:00
# SCHEDULE_DAILY_REVIEW_TIME=15:00  # default: 15:00
# SCHEDULE_LONGTERM_MONDAY_DOW=mon  # default: mon
# SCHEDULE_LONGTERM_MONDAY_TIME=09:00  # default: 09:00
# SCHEDULE_LONGTERM_FRIDAY_DOW=fri  # default: fri
# SCHEDULE_LONGTERM_FRIDAY_TIME=15:00  # default: 15:00

# --- 3. Market-data providers -------------------------------------------------

# TUSHARE_TOKEN=<your_tushare_token>  # default: empty
TUSHARE_QFQ_ENABLED=false
# TUSHARE_HTTP_BASE_URL=http://api.tushare.pro  # default: http://api.tushare.pro
# TUSHARE_TIMEOUT_SECONDS=15.0  # default: 15.0
# TUSHARE_ADJ_FACTOR_MIN_INTERVAL_SECONDS=65.0  # default: 65.0
TICKFLOW_ENABLED=false
# TICKFLOW_API_KEY=<your_tickflow_api_key>  # default: empty
# TICKFLOW_BASE_URL=https://api.tickflow.org  # default: https://api.tickflow.org
# TICKFLOW_TIMEOUT_SECONDS=10.0  # default: 10.0
IFIND_MCP_ENABLED=false
# IFIND_MCP_TOKEN=<your_ifind_mcp_token>  # default: empty
# IFIND_MCP_BASE_URL=https://api-mcp.51ifind.com:8643/ds-mcp-servers  # default: https://api-mcp.51ifind.com:8643/ds-mcp-servers
# IFIND_MCP_TIMEOUT_SECONDS=12.0  # default: 12.0
# IFIND_MCP_QPS_LIMIT=1.0  # default: 1.0

# --- 4. Signal profile and promotion gates ------------------------------------

# QLIB_TRAIN_IC_FLOOR=0.04  # default: 0.04
# QLIB_TRAIN_ICIR_FLOOR=0.4  # default: 0.4
# QLIB_TRAIN_REQUIRE_MONOTONIC=true  # default: true
# WEIGHT_QUANT=0.0  # default: 0.0
# WEIGHT_TECHNICAL=0.6  # default: 0.6
# WEIGHT_SENTIMENT=0.4  # default: 0.4
# NEW_FRAMEWORK_ENTRY_THRESHOLD=25.0  # default: 25.0
# PAPER_TRADING_PROFILE=auto  # default: auto
# TEST1_START_DATE=2026-05-13  # default: 2026-05-13
# TEST1_END_DATE=2026-05-20  # default: 2026-05-20
# TEST1_MULTI_AGENT_ENABLED=false  # default: false
# TEST1_WEIGHT_QUANT=0.45  # default: 0.45
# TEST1_WEIGHT_TECHNICAL=0.4  # default: 0.4
# TEST1_WEIGHT_SENTIMENT=0.15  # default: 0.15
# TEST1_ENTRY_THRESHOLD=20.0  # default: 20.0

# --- 5. Risk, exits, regime, and sizing ---------------------------------------

# ATR_PERIOD=14  # default: 14
# ATR_MULTIPLIER=2.0  # default: 2.0
# RISK_REWARD_RATIO=2.0  # default: 2.0
# TAKE_PROFIT_EXIT_ENABLED=false  # default: false
# TIME_EXIT_ENABLED=false  # default: false
# MAX_HOLD_DAYS=10  # default: 10
# TRAILING_STOP_ENABLED=true  # default: true
# TRAILING_ATR_MULT=2.5  # default: 2.5
# REGIME_FILTER_ENABLED=true  # default: true
# RSRS_WINDOW=18  # default: 18
# RSRS_LOOKBACK=600  # default: 600
# RSRS_BEARISH_Z=-0.7  # default: -0.7
# RSRS_BULLISH_Z=0.7  # default: 0.7
# DIFFUSION_THRESHOLD=0.3  # default: 0.3
# DIFFUSION_STRONG_THRESHOLD=0.6  # default: 0.6
# REGIME_DAMPEN_FACTOR=0.7  # default: 0.7
# ADX_FILTER_ENABLED=false  # default: false
# ADX_THRESHOLD=20.0  # default: 20.0
# POSITION_SIZING_ENABLED=true  # default: true
# PORTFOLIO_MODE=focus  # focus / diversified; default: focus
# MAX_POSITION_PER_STOCK=0.15  # default: 0.15
# MAX_POSITION_PER_SECTOR=0.3  # default: 0.3
# MAX_TOTAL_EQUITY_PCT=0.8  # default: 0.8
# NEW_SIGNAL_TRIAL_PCT=0.05  # default: 0.05
# ENTRY_RISK_BUDGET_PCT=1.5  # default: 1.5
# ENTRY_ACCOUNT_SIZE=  # default: empty; when set, entry cards show reference shares and amount
# M59_DISCRETION_ENABLED=false  # default: false; M59 LLM discretion layer gray-release flag

# --- 6. Agent debate, ATLAS, and research switches ----------------------------

# MULTI_AGENT_ENABLED=false  # default: false
# RISK_MANAGER_ENABLED=true  # default: true
# LAYERED_MEMORY_ENABLED=true  # default: true
# MULTI_ROUND_DEBATE_ENABLED=true  # default: true
# MULTI_ROUND_DEBATE_MIN_DIVERGENCE=20.0  # default: 20.0
# MULTI_ROUND_DEBATE_MAX_ROUNDS=3  # default: 3
# RESEARCH_DIRECTOR_ENABLED=true  # default: true
# DIRECTOR_MIN_CONFIDENCE=0.25  # default: 0.25
# ATLAS_ENABLED=false  # default: false
# STRESS_TEST_ENABLED=true  # default: true
# THESIS_LEDGER_ENABLED=true  # default: true
# THEME_ENGINE_ENABLED=true  # default: true
# REVIEW_LOOP_ENABLED=true  # default: true
# UNIVERSE_GUARD_ENABLED=true  # default: true
# FORWARD_THESIS_ENABLED=true  # default: true
# GATE_B_TRACKER_ENABLED=false  # default: false
# PORTFOLIO_MANAGER_ENABLED=true  # default: true
# RESEARCH_REPORT_GATE_ENABLED=true  # default: true
# RESEARCH_L0_RECALL_ENABLED=true  # default: true

# --- 7. Long-term team and QFII flow ------------------------------------------

# LONG_TERM_TEAM_ENABLED=true  # default: true
# LONG_TERM_TRACK_ENABLED=true  # default: true
# LONG_TERM_PIOTROSKI_ENABLED=true  # default: true
# LONG_TERM_JINGQI_ENABLED=true  # default: true
# LONG_TERM_TRACK_WEIGHT=0.3  # default: 0.3
# LONG_TERM_PIOTROSKI_WEIGHT=0.3  # default: 0.3
# LONG_TERM_JINGQI_WEIGHT=0.4  # default: 0.4
# PIOTROSKI_STRONG_THRESHOLD=7  # default: 7
# PIOTROSKI_WEAK_THRESHOLD=4  # default: 4
# JINGQI_STRONG_PCTILE=0.7  # default: 0.7
# JINGQI_WEAK_PCTILE=0.3  # default: 0.3
# LONG_TERM_LABEL_TTL_DAYS=10  # default: 10
# LONG_TERM_LABEL_MIRROR_PATH=  # default: empty
LONG_TERM_CONSTRAINTS_ENABLED=false
# LONG_TERM_AVOID_BLOCKS_BUY=true  # default: true
# LONG_TERM_OVERVALUED_POSITION_FACTOR=0.5  # default: 0.5
# LONG_TERM_WATCH_SCORE_CAP=30.0  # default: 30.0
# LONG_TERM_MAX_LLM_CALLS_PER_WEEK=60  # default: 60
# FINANCIAL_BACKFILL_YEARS=5  # default: 5
# LONG_TERM_QFII_FLOW_ENABLED=true  # default: true
# LONG_TERM_QFII_FLOW_WEIGHT=0.1  # default: 0.1
# LONG_TERM_SERENITY_ENABLED=false  # default: false
# QFII_FLOW_LOOKBACK_QUARTERS=4  # default: 4
# QFII_FLOW_MIN_HOLDERS=2  # default: 2
# QFII_FLOW_MIN_DROP_QUARTERS=2  # default: 2
# QFII_FLOW_DROP_RATIO=0.2  # default: 0.2

# --- 8. Optional model/data experiments ---------------------------------------

# KRONOS_ENABLED=false  # default: false
# KRONOS_MODEL=NeoQuasar/Kronos-small  # default: NeoQuasar/Kronos-small
# KRONOS_PRED_LEN=5  # default: 5
# KRONOS_WEIGHT_IN_QUANT=0.4  # default: 0.4
# NEWS_ADAPTERS_ENABLED=["eastmoney"]  # default: ["eastmoney"]
# NEWS_V2_PYRAMID_ENABLED=true  # default: true
# NEWS_V2_PYRAMID_TRIGGER_ONLY=true  # default: true

# --- 9. Search/news supplements and notifications -----------------------------

# TAVILY_API_KEY=<your_tavily_api_key>  # default: empty
# TAVILY_SUPPLEMENT_THRESHOLD=3  # default: 3
# ANSPIRE_API_KEY=<your_anspire_api_key>  # default: empty
# ANSPIRE_NEWS_DAYS=2  # default: 2
# ANSPIRE_NEWS_MAX_RESULTS=5  # default: 5
# ANSPIRE_NEWS_MAX_ADD=2  # default: 2
# ANSPIRE_NEWS_MIN_SCORE=75  # default: 75
# BARK_KEY=<your_bark_device_key>  # default: empty
# BARK_SERVER=https://api.day.app  # default: https://api.day.app
# LLM_DAILY_BUDGET_CNY=1.0  # default: 1.0
# LLM_DAILY_BUDGET_TOKENS_SENTIMENT=0  # default: 0

# --- 10. M60 Watchtower --------------------------------------------------------

# WATCHTOWER_LOOKBACK_DAYS=250  # default: 250
# WATCHTOWER_PRICE_Z_THRESHOLD=2.0  # default: 2.0
# WATCHTOWER_PRICE_PERCENTILE=0.9  # default: 0.9
# WATCHTOWER_VOLUME_RATIO_THRESHOLD=2.0  # default: 2.0
# WATCHTOWER_VOLUME_LOOKBACK_DAYS=20  # default: 20
# WATCHTOWER_NEW_HIGH_LOOKBACK_DAYS=20  # default: 20
# WATCHTOWER_NEWS_LOOKBACK_DAYS=3  # default: 3
# WATCHTOWER_SECTOR_RESONANCE_MIN_RATIO=0.5  # default: 0.5
# WATCHTOWER_SECTOR_RESONANCE_MIN_AVG_PCT=1.5  # default: 1.5

# --- 11. Optional local/remote agent guardrails --------------------------------

MINGCANG_AGENT_MODE=local
# MINGCANG_AGENT_API_KEY=<your_remote_agent_api_key>  # default: empty
# MINGCANG_AGENT_REMOTE_WRITE_ENABLED=false  # default: false
# MINGCANG_AGENT_REMOTE_WRITE_ACTIONS=  # default: empty
